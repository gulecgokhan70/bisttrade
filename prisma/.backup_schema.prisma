// CRITICAL: This schema file is shared across multiple applications. Only make edits with explicit user consent. Changes here affect all apps using this database.

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/stock_trading_app/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  cashBalance   Float     @default(100000)
  isGuest       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  holdings      Holding[]
  transactions  Transaction[]
  priceAlerts   PriceAlert[]
  portfolioSnapshots PortfolioSnapshot[]
  orders        Order[]
  autoStrategies AutoStrategy[]
  watchlist     Watchlist[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Stock {
  id          String   @id @default(cuid())
  symbol      String   @unique
  name        String
  sector      String?
  exchange    String   @default("BIST")
  basePrice   Float
  currentPrice Float
  previousClose Float
  dayHigh     Float?
  dayLow      Float?
  volume      BigInt   @default(0)
  marketCap   Float?
  logoUrl     String?
  yahooSymbol String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  holdings    Holding[]
  transactions Transaction[]
  priceAlerts  PriceAlert[]
  priceHistory PriceHistory[]
  orders       Order[]
  autoStrategies AutoStrategy[]
  watchlist    Watchlist[]
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
}

model Holding {
  id            String   @id @default(cuid())
  userId        String
  stockId       String
  quantity      Float
  avgBuyPrice   Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock         Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  stockId     String
  type        String
  orderType   String   @default("MARKET")
  quantity    Float
  price       Float
  totalAmount Float
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock       Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Order {
  id              String    @id @default(cuid())
  userId          String
  stockId         String
  type            String
  orderType       String
  quantity        Float
  limitPrice      Float?
  stopPrice       Float?
  trailingPercent Float?
  status          String    @default("PENDING")
  expiresAt       DateTime?
  executedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock           Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stockId, status])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  stockId     String
  targetPrice Float
  condition   String
  isActive    Boolean  @default(true)
  triggered   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock       Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model PriceHistory {
  id        String   @id @default(cuid())
  stockId   String
  price     Float
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  volume    BigInt   @default(0)
  timestamp DateTime @default(now())
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, timestamp])
}

model PortfolioSnapshot {
  id         String   @id @default(cuid())
  userId     String
  totalValue Float
  cashBalance Float
  timestamp  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model AutoStrategy {
  id          String   @id @default(cuid())
  userId      String
  stockId     String
  strategy    String   // SMA_CROSSOVER, RSI_STRATEGY, MACD_STRATEGY, BOLLINGER_STRATEGY, COMBINED
  mode        String   @default("normal") // normal, aggressive
  isActive    Boolean  @default(true)
  maxAmount   Float    @default(50000)
  maxQuantity Int      @default(100)
  checkInterval Int    @default(60)  // seconds
  lastChecked DateTime?
  lastSignal  String?
  totalTrades Int      @default(0)
  totalPnL    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock       Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId, strategy])
  @@index([userId])
  @@index([isActive])
}
